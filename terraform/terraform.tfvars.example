# AWS AgentCore Workshop: MarketPulse - Example Configuration
# Copy this file to terraform.tfvars and update with your values

# ============================================================================
# Project Configuration
# ============================================================================
project_name = "marketpulse"

# Set environment to your name or a unique identifier.
# If multiple engineers are deploying to the same AWS account, each person
# must use a different value here to avoid resource name collisions.
# e.g. "alice", "bob", "eng01"
environment = "workshop"

# AWS Region - Choose a region that supports Bedrock and AgentCore
aws_region = "ap-southeast-2"

# ============================================================================
# Feature Flags - Enable Modules by Phase
# ============================================================================

# Phase 1: Foundation (always false in Phase 1)
enable_gateway       = false
enable_http_target   = false
enable_lambda_target = false
enable_mcp_target    = false
enable_memory        = false
enable_identity      = false
enable_observability = false

# Phase 2: Runtime + Gateway + HTTP Target
# enable_gateway       = true
# enable_http_target   = true

# Phase 3: Add Lambda Target
# enable_lambda_target = true

# Phase 4: Add MCP Server Target
# enable_mcp_target    = true

# Phase 5: Add Memory
# enable_memory        = true

# Phase 6: Add Identity (OAuth 2.0)
# enable_identity      = true

# Phase 7: Add Observability (Tracing)
# enable_observability = true

# ============================================================================
# API Keys (Required for Phase 2+)
# ============================================================================

# Finnhub API Key - Get free key at https://finnhub.io
# Required when enable_http_target = true
# 
# WORKSHOP SETUP:
# 1. Get your free API key: https://finnhub.io
# 2. Uncomment the line below and paste your key
# 3. Save this file and run terraform apply
# 
# This file is in .gitignore - your key is safe!
# 
# finnhub_api_key = "paste-your-key-here"

# ============================================================================
# Bedrock Configuration
# ============================================================================

# Model ID for agent runtime - use cross-region inference profile, not the bare model ID
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles.html
bedrock_model_id = "au.anthropic.claude-sonnet-4-5-20250929-v1:0"

# Model inference parameters
model_temperature = 0.7
model_max_tokens  = 4096

# ============================================================================
# Tags (Optional but Recommended)
# ============================================================================
tags = {
  Workshop    = "AWS AgentCore MarketPulse"
  ManagedBy   = "Terraform"
  CostCentre  = "Training"
  Owner       = "your-name@example.com"
  Repository  = "github.com/your-org/aws-agentcore-workshop"
}